# =============================================================
# FridgeChef — Environment Variables Reference
# Copy this file to .env (root) for local dev.
# Never commit .env to version control.
# =============================================================

# ── Server ────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── MongoDB ───────────────────────────────────────────────────
# Get from: https://cloud.mongodb.com → Clusters → Connect
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/fridgechef?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────────
# Use a strong random string: `openssl rand -base64 64`
JWT_SECRET=replace_with_strong_random_secret
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=replace_with_different_strong_secret
REFRESH_TOKEN_EXPIRES_IN=7d

# ── Cloudinary ────────────────────────────────────────────────
# Get from: https://console.cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_UPLOAD_FOLDER=fridgechef/uploads

# ── FatSecret ─────────────────────────────────────────────────
# Get from: https://platform.fatsecret.com/api/Default.aspx
# Required scope: basic image_recognition
FATSECRET_CLIENT_ID=your_client_id
FATSECRET_CLIENT_SECRET=your_client_secret

# ── Spoonacular ───────────────────────────────────────────────
# Get from: https://spoonacular.com/food-api
# Rate limit: 60 requests/minute
SPOONACULAR_API_KEY=your_api_key
SPOONACULAR_RATE_LIMIT=60

# ── Frontend (Vite — prefix with VITE_) ──────────────────────
VITE_API_BASE_URL=http://localhost:5000/api
